<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Mario Lava Game</title>
<style>
body { margin:0; overflow:hidden; background:black; font-family: Arial; }
canvas { display:block; }
.menu {
  position:absolute;
  top:50%;
  left:50%;
  transform:translate(-50%,-50%);
  text-align:center;
}
button {
  display:block;
  margin:10px;
  padding:10px 20px;
  font-size:20px;
  cursor:pointer;
}
</style>
</head>
<body>

<div id="menu" class="menu">
  <h1 style="color:white;">Mario Lava Game</h1>
  <button onclick="startGame()">▶ Play</button>
  <button onclick="showSettings()">⚙ Ajustes</button>
  <button onclick="exitGame()">❌ Salir</button>
</div>

<div id="settings" class="menu" style="display:none;">
  <h2 style="color:white;">Dificultad</h2>
  <button onclick="setDifficulty('easy')">Fácil</button>
  <button onclick="setDifficulty('medium')">Medio</button>
  <button onclick="setDifficulty('hard')">Difícil</button>
  <button onclick="backMenu()">⬅ Volver</button>
</div>

<canvas id="game" style="display:none;"></canvas>

<script>
let difficulty = "medium";

// MENU FUNCTIONS
function startGame(){
  document.getElementById("menu").style.display = "none";
  document.getElementById("settings").style.display = "none";
  document.getElementById("game").style.display = "block";
  initGame();
}

function showSettings(){
  document.getElementById("menu").style.display = "none";
  document.getElementById("settings").style.display = "block";
}

function backMenu(){
  document.getElementById("settings").style.display = "none";
  document.getElementById("menu").style.display = "block";
}

function setDifficulty(level){
  difficulty = level;
  alert("Dificultad: " + level);
}

function exitGame(){
  alert("Gracias por jugar 😎");
}

// GAME SETUP
const canvas = document.getElementById("game");
const ctx = canvas.getContext("2d");

canvas.width = window.innerWidth;
canvas.height = window.innerHeight;

let player, lava, platforms, obstacles, coins, goal;
let gameText = "READY!";

function initGame(){

// Difficulty settings
let jump = -15;
let fallSpeed = 0.5;
let obstaclePush = 5;

if(difficulty === "medium"){
  jump = -13;
  fallSpeed = 1;
  obstaclePush = 10;
}
if(difficulty === "hard"){
  jump = -12;
  fallSpeed = 2;
  obstaclePush = 20;
}

// Player
player = {
  x:100,
  y:300,
  width:40,
  height:40,
  velocityY:0,
  gravity:0.6,
  jumpForce:jump,
  isGrounded:false,
  score:0
};

// Lava
lava = { y: canvas.height - 50, height: 50 };

// Platforms
platforms = [
  {x:0,y:400,width:300,height:20,fall:false},
  {x:350,y:350,width:200,height:20,fall:false},
  {x:600,y:300,width:200,height:20,fall:false}
];

// Obstacles
obstacles = [
  {x:400,y:320,size:30},
  {x:650,y:270,size:30}
];

// Coins
coins = [
  {x:200,y:350,radius:10,collected:false},
  {x:500,y:300,radius:10,collected:false}
];

// Goal
goal = { x:700,y:250,width:40,height:60 };

// READY / GO
gameText = "READY!";
setTimeout(()=> gameText="GO!",2000);

// Controls
document.addEventListener("keydown", e => keys[e.key] = true);
document.addEventListener("keyup", e => keys[e.key] = false);

// Loop
function loop(){
ctx.clearRect(0,0,canvas.width,canvas.height);

// Movement
if(keys["ArrowRight"]) player.x += 5;
if(keys["ArrowLeft"]) player.x -= 5;

// Jump
if(keys[" "] && player.isGrounded){
  player.velocityY = player.jumpForce;
  player.isGrounded = false;
}

// Gravity
player.velocityY += player.gravity;
player.y += player.velocityY;
player.isGrounded = false;

// Platforms
platforms.forEach(p=>{
  if(player.x < p.x + p.width &&
     player.x + player.width > p.x &&
     player.y + player.height >= p.y &&
     player.y + player.height <= p.y + 10){
     
     player.y = p.y - player.height;
     player.velocityY = 0;
     player.isGrounded = true;
     p.fall = true;
  }
  if(p.fall) p.y += fallSpeed;
});

// Obstacles
obstacles.forEach(o=>{
  if(player.x < o.x + o.size &&
     player.x + player.width > o.x &&
     player.y < o.y + o.size &&
     player.y + player.height > o.y){
     player.x -= obstaclePush;
  }
});

// Lava
if(player.y + player.height > lava.y){
  alert("🔥 Game Over");
  location.reload();
}

// Coins
coins.forEach(c=>{
  let dx = player.x - c.x;
  let dy = player.y - c.y;
  if(Math.sqrt(dx*dx+dy*dy) < 30 && !c.collected){
    c.collected = true;
    player.score += 10;
  }
});

// Goal
if(player.x < goal.x + goal.width &&
   player.x + player.width > goal.x &&
   player.y < goal.y + goal.height &&
   player.y + player.height > goal.y){
   alert("🏆 YOU WIN!");
   location.reload();
}

// Draw
ctx.fillStyle="orange";
ctx.fillRect(0,lava.y,canvas.width,lava.height);

ctx.fillStyle="brown";
platforms.forEach(p=>ctx.fillRect(p.x,p.y,p.width,p.height));

ctx.fillStyle="blue";
obstacles.forEach(o=>ctx.fillRect(o.x,o.y,o.size,o.size));

ctx.fillStyle="yellow";
coins.forEach(c=>{
  if(!c.collected){
    ctx.beginPath();
    ctx.arc(c.x,c.y,c.radius,0,Math.PI*2);
    ctx.fill();
  }
});

ctx.fillStyle="green";
ctx.fillRect(goal.x,goal.y,goal.width,goal.height);

ctx.fillStyle="red";
ctx.fillRect(player.x,player.y,player.width,player.height);

// HUD
ctx.fillStyle="white";
ctx.font="20px Arial";
ctx.fillText("Score: "+player.score,20,30);

ctx.font="40px Arial";
ctx.fillText(gameText,canvas.width/2-80,100);

requestAnimationFrame(loop);
}
loop();
}

let keys = {};
</script>

</body>
</html>
